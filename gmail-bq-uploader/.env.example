# ── Google OAuth2 (OAuth クライアント ID・シークレット) ──────────────────
# GCP Console > API とサービス > 認証情報 > OAuth 2.0 クライアント ID から取得
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Cloud Run にデプロイ後は実際の URL に変更
REDIRECT_URI=http://localhost:8501

# ── BigQuery 書き込み用サービスアカウント ────────────────────────────────
# 方法1: JSON キーファイルのパスを指定
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=/path/to/service-account-key.json

# 方法2: JSON キーの内容を直接環境変数に設定（Cloud Run 推奨）
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account","project_id":"booking-data-388605",...}
